{
  "name": "liteclaw",
  "version": "0.7.0",
  "description": "Lightweight agent runtime for local LLMs — WebUI, Discord, WhatsApp",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "liteclaw": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs'); fs.cpSync('src/channels/webui', 'dist/channels/webui', {recursive:true, force:true});\"",
    "dev": "npm run build && tsx src/index.ts",
    "start": "npm run build && node dist/index.js",
    "cli": "tsx src/cli.ts",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "agent",
    "llm",
    "local",
    "discord",
    "whatsapp",
    "chatbot"
  ],
  "license": "MIT",
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^12.9.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "discord.js": "^14.26.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mammoth": "^1.12.0",
    "mime-types": "^3.0.2",
    "openai": "^6.34.0",
    "ora": "^9.3.0",
    "pdf-parse": "^2.4.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sharp": "^0.34.5",
    "ws": "^8.20.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.1/xlsx-0.20.1.tgz",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
