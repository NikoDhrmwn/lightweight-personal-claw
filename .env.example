# LiteClaw Environment Variables
# Copy this to .env and fill in your values

# Discord Bot Token
DISCORD_TOKEN=

# Google API Key (for Grounding search + Gemini fallback)
GOOGLE_API_KEY=

# Gateway auth token (auto-generated if empty)
GATEWAY_TOKEN=

# LLM Backend URL (default: llama-server)
LLM_BASE_URL=http://localhost:8080/v1
LLM_API_KEY=sk-local
LLM_MODEL=gemma-4-e4b-heretic
